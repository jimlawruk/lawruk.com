@model lawrukmvc.ViewModels.HomeViewModel

@{
    Layout = null;
    ViewBag.Title = "Index.Mobile";
}

<!DOCTYPE html>

<html>
<head>
    <title>Lawruk.com</title>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.7.1/jquery.js"></script>   
    <link href="/Content/iphone.css" rel="stylesheet" type="text/css" />
    <meta name="viewport" content="width=device-width; initial-scale=1.0; maximum-scale=1.0; user-scalable=0;" /> 
</head>
<body class="home">

<div class="navbar home">
    <div class="navbar-inner">
        <a class="brand">Lawruk.com</a>
    </div>
</div>
<div class="container home" style="width:320px;">
    <div>
        <div class="row">            
            @foreach (var button in Model.HomeButtons)
            {
                <div class="icon">           
                    <a href="@button.Url" class="home-link">
										<img src="@button.ImageUrl" class="nav-img" alt="" role="presentation" style="display:block; width:100%;height:80%;"/>
										<span class="personaName">@button.Title</span>
										</a>
                </div>            
            }
            
            
        </div>
    </div>
</div>
</body>
</html>

